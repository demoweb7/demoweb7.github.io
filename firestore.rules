// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: analysts
// Document ID: analystId (UUID)
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - username: string (required)
//   - password: string (required)
//   - role: string (required, enum: admin, analyst)
//   - break1: map (required)
//     - checked: boolean
//     - time: string
//     - startTime: number
//     - endTime: number
//   - break2: map (required)
//     - checked: boolean
//     - time: string
//     - startTime: number
//     - endTime: number
//
// Collection: activeBreaks
// Document ID: activeBreakId (UUID)
// Fields:
//   - id: string (required)
//   - analystId: string (required)
//   - analystName: string (required)
//   - breakName: string (required)
//   - startTime: number (required)
//
// Collection: settings
// Document ID: global
// Fields:
//   - lastResetDate: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "clinicabiobio1@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidAnalyst(data) {
      return data.keys().hasAll(['id', 'name', 'username', 'password', 'role', 'break1', 'break2']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.username is string && data.username.size() > 0 &&
             data.password is string && data.password.size() > 0 &&
             data.role in ['admin', 'analyst'] &&
             data.break1 is map &&
             data.break2 is map;
    }

    function isValidActiveBreak(data) {
      return data.keys().hasAll(['id', 'analystId', 'analystName', 'breakName', 'startTime']) &&
             data.id is string &&
             data.analystId is string &&
             data.analystName is string &&
             data.breakName is string &&
             data.startTime is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /analysts/{analystId} {
      allow read, write: if true;
    }

    match /activeBreaks/{activeBreakId} {
      allow read, write: if true;
    }

    match /settings/global {
      allow read, write: if true;
    }
  }
}
